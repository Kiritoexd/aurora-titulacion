@model AURORA.Models.ResetPasswordViewModel

<div class="reset-container">
    <div class="reset-card">
        <h2 class="reset-title">Restablecer contraseña</h2>
        <form asp-action="ResetPassword" method="post" id="resetForm">
            <div class="form-group mb-3">
                <label for="Token">Código de recuperación</label>
                <input asp-for="Token" class="form-control input-dark" required />
            </div>
            <div class="form-group mb-3">
                <label for="NewPassword">Nueva contraseña</label>
                <input asp-for="NewPassword" type="password" class="form-control input-dark" required />
            </div>
            <button type="submit" class="btn-reset">Guardar</button>
        </form>
    </div>
</div>

<script>
    // Permitir enviar con Enter
    document.getElementById("resetForm").addEventListener("keypress", function(e) {
        if (e.key === "Enter") {
            e.preventDefault();
            this.submit();
        }
    });
</script>
