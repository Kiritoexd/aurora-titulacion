@model AURORA.Models.PerfilViewModel
@{
    ViewData["Title"] = "Mi Perfil";
}

<link rel="stylesheet" href="~/css/Perfil.css" asp-append-version="true" />

<div class="perfil-wrapper">

    <!-- ── Encabezado ── -->
    <div class="perfil-header">
        <div class="foto-wrapper">
            <div class="perfil-foto-circle">
                <img src="@(string.IsNullOrEmpty(Model.FotoUrl) ? "/img/user.png" : Model.FotoUrl)"
                     alt="Foto de perfil"
                     class="perfil-foto" />
            </div>
        </div>
        <div class="perfil-header-info">
            <h2 class="perfil-nombre">@Model.NombreCompleto</h2>
            <p class="perfil-email">@Model.Email</p>
            <span class="perfil-fecha-badge">
                <i class="ti ti-calendar" aria-hidden="true"></i>
                Registrado: @Model.FechaRegistro.ToShortDateString()
            </span>
        </div>
    </div>

    <div class="perfil-grid">

        <!-- Tarjeta edición -->
        <div class="card perfil-card">
            <p class="pcard-label">Editar perfil</p>
            <form asp-controller="Lector" asp-action="EditarPerfil" method="post" class="perfil-form">
                <input type="hidden" name="Id" value="@Model.Id" />
                <label>Nombres</label>
                <input type="text" name="Nombres" value="@Model.Nombres" />
                <label>Apellido Paterno</label>
                <input type="text" name="ApellidoPaterno" value="@Model.ApellidoPaterno" />
                <label>Apellido Materno</label>
                <input type="text" name="ApellidoMaterno" value="@Model.ApellidoMaterno" />
                <label>Correo</label>
                <input type="email" name="Email" value="@Model.Email" />
                <button type="submit" class="btn-guardar">Guardar cambios</button>
            </form>

            <form asp-controller="Lector" asp-action="SubirFoto" method="post"
                  enctype="multipart/form-data" class="foto-form">
                <input type="file" name="foto" class="input-file" />
                <button type="submit" class="btn-foto">Actualizar foto</button>
            </form>
        </div>

        <!-- ── Tarjeta racha REAL ── -->
        <div class="card perfil-card">
            <p class="pcard-label">Racha de lectura</p>

            <div class="racha-nums">
                <span class="racha-big">@Model.DiasSeguidos</span>
                <span class="racha-unit">días seguidos</span>
            </div>

            <div class="racha-bar">
                <div class="racha-progreso"
                     id="rachaFill"
                     style="width: 0%"
                     data-target="@Model.RachaPct.ToString("F0")%">
                </div>
            </div>

            <span class="racha-meta">Meta: @Model.MetaDias días</span>

            @{
                var restantes = Model.MetaDias - Model.DiasSeguidos;
            }
            <span class="racha-restantes">
                @if (restantes > 0)
                {
                    <span>Faltan <strong>@restantes días</strong> para tu meta</span>
                }
                else
                {
                    <span>🎉 ¡Meta alcanzada!</span>
                }
            </span>

            <!-- Enlace a la vista completa de racha -->
            <a asp-controller="Lector" asp-action="Racha" class="racha-ver-mas">
                Ver racha completa →
            </a>
        </div>

        <!-- Tarjeta acciones -->
        <div class="card perfil-card acciones">
            <p class="pcard-label">Acciones</p>
            <a asp-controller="Usuario" asp-action="Logout" class="btn-logout">
                <i class="ti ti-logout" aria-hidden="true"></i>
                Cerrar sesión
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        window.addEventListener('DOMContentLoaded', () => {
            const fill = document.getElementById('rachaFill');
            if (fill) setTimeout(() => fill.style.width = fill.dataset.target, 80);
        });
    </script>
}