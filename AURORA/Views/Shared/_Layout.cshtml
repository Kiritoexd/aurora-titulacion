<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aurora</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.47.0/tabler-icons.min.css" />
</head>
<body>
    <!-- Overlay móvil -->
<div class="aurora-overlay" id="sidebarOverlay"></div>

<!-- Topbar solo visible en móvil -->
<div class="aurora-topbar">
    <button id="toggleSidebarMobile" class="aurora-toggle" aria-label="Abrir menú">
        <span></span><span></span><span></span>
    </button>
    <span class="aurora-topbar-brand">AURORA</span>
</div>
    <div class="aurora-shell">

        <!-- Sidebar -->
        <aside class="aurora-sidebar" id="sidebar">
            <div class="aurora-sidebar-header">
                <span class="aurora-brand">AURORA</span>
                <button id="toggleSidebar" class="aurora-toggle" aria-label="Colapsar menú">
                    <span></span><span></span><span></span>
                </button>
            </div>

            <nav class="aurora-nav">
                @if (User.Identity.IsAuthenticated)
                {
                    @if (User.IsInRole("Administrador"))
                    {
                        <a class="aurora-nav-link" asp-controller="Administrador" asp-action="Index">
                            <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>
                            <span>Panel Admin</span>
                        </a>
                        <a class="aurora-nav-link" asp-controller="Administrador" asp-action="Index" asp-route-filtro="activo">
                            <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" /></svg>
                            <span>Usuarios activos</span>
                        </a>
                        <a class="aurora-nav-link" asp-controller="Administrador" asp-action="Index" asp-route-filtro="baja">
                            <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="23" y1="11" x2="17" y2="11" /></svg>
                            <span>De baja</span>
                        </a>
                    }

                    @if (User.IsInRole("Lector"))
                    {
                        <a class="aurora-nav-link" asp-controller="Lector" asp-action="Inicio">
                            <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z" /></svg>
                            <span>Inicio</span>
                        </a>
                        <a class="aurora-nav-link" asp-controller="Lector" asp-action="Perfil">
                            <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" /></svg>
                            <span>Perfil</span>
                        </a>
                        <a class="aurora-nav-link" asp-controller="Lector" asp-action="Biblioteca">
                            <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="18" rx="1" /><rect x="13" y="3" width="8" height="11" rx="1" /><rect x="13" y="17" width="8" height="4" rx="1" /></svg>
                            <span>Biblioteca</span>
                        </a>
                        <a class="aurora-nav-link" asp-controller="Lector" asp-action="Recomendaciones">
                            <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
                            <span>Recomendaciones</span>
                        </a>
                        <a class="aurora-nav-link" asp-controller="Lector" asp-action="Estadisticas">
                            <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>
                            <span>Estadísticas</span>
                        </a>
                        <a class="aurora-nav-link" asp-controller="Lector" asp-action="Top">
                            <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" /></svg>
                            <span>Top</span>
                        </a>
                        <a class="aurora-nav-link" asp-controller="Groq" asp-action="IA">
                            <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3" /><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12" /></svg>
                            <span>IA</span>
                        </a>
                        <a class="aurora-nav-link" asp-controller="Lector" asp-action="Racha">
                            <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L4.5 13.5H11L10 22l8.5-11.5H13L14 2z" /></svg>
                            <span>Racha</span>
                        </a>
                        <a class="aurora-nav-link" asp-controller="Lector" asp-action="Logros">
                            <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z" />
                            </svg>
                            <span>Logros</span>
                        </a>
                    }

                    <div class="aurora-nav-divider"></div>

                    <a class="aurora-nav-link aurora-nav-logout" asp-controller="Usuario" asp-action="Logout">
                        <svg class="aurora-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                        <span>Cerrar sesión</span>
                    </a>
                }
            </nav>

            <div class="aurora-glow" aria-hidden="true"></div>
        </aside>

        <!-- Main Content -->
        <main class="aurora-main">
            <div class="aurora-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/JavaScript.js" asp-append-version="true"></script>
    <script>
        const sidebar = document.getElementById('sidebar');
        document.getElementById('toggleSidebar').addEventListener('click', () => {
        sidebar.classList.toggle('collapsed');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
